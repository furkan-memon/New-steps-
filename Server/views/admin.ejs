<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Scatch Admin</title>

    <link
      href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css"
      rel="stylesheet"
    />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" integrity="sha512-2SwdPD6INVrV/lHTZbO2nodKhrnDdJK9/kg2XD1r9uGqPo1cUbujc+IYdlYdEErWNu69gVcYgdxlmVmzTWnetw==" crossorigin="anonymous" referrerpolicy="no-referrer" />

    <script src="https://cdn.tailwindcss.com"></script>
  </head>

  <body class="bg-gray-100 text-gray-800">
    <!-- Navbar -->
    <nav class="fixed top-0 left-0 w-full bg-white border-b z-50">
      <div
        class="max-w-7xl mx-auto flex justify-between items-center px-8 py-4"
      >
        <h3 class="text-xl font-semibold tracking-tight">Scatch</h3>
        <div class="flex gap-6 text-sm font-medium">
          <a href="/owners/admin" class="hover:text-blue-600 transition"
            >All Products</a
          >
          <a href="/owners/addproduct" class="hover:text-blue-600 transition"
            >Create Product</a
          >
        </div>
      </div>
    </nav>

    <!-- Main -->
    <main class="pt-24 max-w-7xl mx-auto px-8">
      <section>
        <!-- Header -->
        <div class="flex justify-between items-center mb-8">
          <h2 class="text-2xl font-semibold">Products</h2>
          
        </div>

        <!-- Products Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          <% products.forEach((product)=>{ %>

            <div
              class="bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-md transition relative"
            >
              <!-- Image -->
              <div class="h-60 relative   w-full bg-gray-200  overflow-hidden rounded-lg ">
                  <img class="w-full absolute    h-full transition-transform duration-300 hover:scale-105" src="data:image/jpeg;base64,<%= product.image.toString('base64') %>" alt="">
              </div>
  
              <!-- Info -->
              <div class="p-4 flex justify-between items-center">
                <div>
                  <h3 class="font-medium leading-tight">                  <%= product.name %>
</h3>
                  <p class="text-sm text-gray-500 mt-1">₹<%= product.price %></p>
                </div>
  
                <!-- Dropdown -->
                <div class="relative">
                  <button
                    class="w-9 h-9 rounded-full hover:bg-gray-100 flex items-center justify-center transition"
                  >
                    <i class="fa-solid fa-ellipsis-vertical"></i>
                  </button>
  
                  <!-- Menu -->
                  <div
                    class="absolute right-0 mt-2 w-32 bg-white border rounded-lg shadow-lg hidden z-20"
                  >
                    <a
                      href="/owners/editproduct/<%= product._id %>"
                      class="block px-4 py-2 text-sm hover:bg-gray-100"
                    >
                      Edit
                    </a>
                    <a
                      href="/owners/deleteproduct/<%= product._id %>"
                      class="block px-4 py-2 text-sm text-red-500 hover:bg-gray-100"
                    >
                      Delete
                    </a>
                  </div>
                </div>
              </div>
            </div>
  
            
         <% }) %>

        </div>
      </section>
    </main>

    <%- include("partials/footer") %>
  
