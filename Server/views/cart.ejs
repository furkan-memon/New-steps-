<%- include("partials/header") %>

<div class="bg-gray-50 min-h-screen px-6 md:px-16 py-10">
  <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-8">

    <!-- Cart Items -->
    <div class="lg:col-span-2 space-y-6">
      <h2 class="text-2xl font-semibold">My Cart</h2>

      <% cart.forEach(item => { %>
      <div class="bg-white rounded-2xl shadow-sm p-5 flex gap-5">

        <!-- Image -->
        <div class="w-28 h-28 rounded-xl bg-gray-100 flex-shrink-0 relative overflow-hidden">
          <% if (item.product && item.product.image) { %>
            <img
              class="w-full h-full object-cover transition-transform duration-300 hover:scale-105"
              src="data:image/jpeg;base64,<%= item.product.image.toString('base64') %>"
              alt=""
            />
          <% } else { %>
            <div class="w-full h-full flex items-center justify-center text-xs text-gray-400">
              No Image
            </div>
          <% } %>
        </div>

        <!-- Info -->
        <div class="flex-1">
          <div class="flex justify-between items-start">
            <h3 class="text-lg font-medium"><%= item.product.name %></h3>
            <span class="text-sm text-gray-500">₹<%= item.product.price %></span>
          </div>

          <!-- Quantity -->
          <div class="mt-4 flex items-center gap-3">
            <button onclick="increaseQty('<%= item.product._id %>')" class="w-8 h-8 rounded-full bg-gray-100 flex items-center justify-center text-lg">+</button>
            <span class="px-3 py-1 rounded bg-gray-100 text-sm"><%= item.qty %></span>
            <button onclick="decreaseQty('<%= item.product._id %>')" class="w-8 h-8 rounded-full bg-gray-100 flex items-center justify-center text-lg">-</button>
          </div>
        </div>
      </div>
      <% }) %>
    </div>

    <!-- Price Details -->
    <div class="bg-white rounded-2xl shadow-sm p-6 h-fit sticky top-24">
      <h3 class="text-lg font-semibold mb-4">Price Details</h3>

      <div class="space-y-3 text-sm text-gray-700">
        <% let total = 0; %>
        <% cart.forEach(item => { total += item.product.price * item.qty }) %>

        <div class="flex justify-between">
          <span>Total MRP</span>
          <span>₹<%= total %></span>
        </div>

        <div class="flex justify-between">
          <span>Delivery</span>
          <span class="text-green-600">FREE</span>
        </div>
      </div>

      <hr class="my-5">

      <div class="flex justify-between items-center text-lg font-semibold">
        <span>Total Amount</span>
        <span class="text-green-600">₹<%= total %></span>
      </div>

      <button class="mt-6 w-full py-3 rounded-xl bg-green-600 text-white font-medium hover:bg-green-500 transition">
        Proceed to Checkout
      </button>
    </div>

  </div>
</div>
<script>

  function decreaseQty(productId) {
    fetch(`/decrease/${productId}`)
      .then(() => location.reload());
  }
    function increaseQty(productId) {
    fetch(`/increaseQty/${productId}`)
      .then(() => location.reload());
  }
</script>
<%- include("partials/footer") %>
