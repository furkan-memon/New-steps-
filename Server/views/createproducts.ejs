<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Scatch</title>

  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="font-['helvetica_now_display'] bg-gray-50">

  <!-- Navbar -->
  <nav class="fixed top-0 left-0 w-full bg-white shadow z-50">
    <div class="flex justify-between items-center px-8 py-4 max-w-7xl mx-auto">
      <h3 class="text-xl font-semibold">Scatch</h3>
      <div class="flex gap-6 text-sm font-medium">
        <a href="/owners/admin" class="hover:text-blue-500">All Products</a>
        <a href="/owners/addproduct" class="hover:text-blue-500">Create New Product</a>
      </div>
    </div>
  </nav>

  <!-- Page -->
  <main class="pt-24 max-w-7xl mx-auto px-8">

  

    <div class="">

      <!-- Sidebar (future use) -->
     

      <!-- Main Content -->
      <section class=" bg-white p-10 rounded-xl shadow">

        <h2 class="text-2xl font-semibold mb-8">Create New Product</h2>

        <form 
          action="/products/create" 
          method="post" 
          enctype="multipart/form-data"
          class="space-y-8"
        >

          <!-- Product Image -->
          <div>
            <label class="block text-sm font-medium mb-2">Product Image</label>
            <input 
              type="file" 
              name="image"
              class="block w-full text-sm text-gray-500
                     file:mr-4 file:py-2 file:px-4
                     file:rounded file:border-0
                     file:bg-gray-100 file:text-gray-700
                     hover:file:bg-gray-200"
            >
          </div>

          <!-- Product Details -->
          <div>
            <h3 class="font-medium mb-4">Product Details</h3>

            <div class="grid grid-cols-3 gap-4">
              <input
                class="border px-3 py-2 rounded focus:outline-none focus:ring-1 focus:ring-blue-500"
                name="name"
                placeholder="Product Name"
                required
              />
              <input
                class="border px-3 py-2 rounded focus:outline-none focus:ring-1 focus:ring-blue-500"
                name="price"
                placeholder="Price"
                required
              />
              <input
                class="border px-3 py-2 rounded focus:outline-none focus:ring-1 focus:ring-blue-500"
                name="discount"
                placeholder="Discount (%)"
              />
            </div>
          </div>

          <!-- Submit -->
          <div class="pt-4">
            <button class="px-6 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 transition">
              Create Product
            </button>
          </div>

        </form>

      </section>
    </div>
  </main>

  <%- include("partials/footer") %>

