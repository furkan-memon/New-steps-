<%- include("partials/header") %>

<div class="w-full flex justify-center items-center min-h-screen flex bg-gray-50">
  <!-- Left: Register -->
  <div class="">
    <div class="w-full max-w-md bg-white p-10 rounded-xl shadow">
      <h3 class="text-3xl font-semibold mb-2">
        Welcome to <span class="text-blue-500">Scatch</span>
      </h3>
      <p class="text-gray-500 mb-6">Create your account</p>

      <form action="/users/register" method="post" class="space-y-4">
        <input class="w-full border px-4 py-2 rounded" name="fullname" placeholder="Full Name">
        <input class="w-full border px-4 py-2 rounded" name="email" placeholder="Email">
        <input class="w-full border px-4 py-2 rounded" type="password" name="password" placeholder="Password">

        <button class="w-full py-2 bg-blue-600 text-white rounded hover:bg-blue-700">
          Create Account
        </button>
      </form>
    </div>
  </div>

  <!-- Right: Login -->
 
</div>
<%- include("partials/footer") %>
