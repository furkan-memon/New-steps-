<%- include("partials/header") %>
  
  <div class=" flex items-center justify-center">
    <div class="w-full max-w-md bg-white p-10 rounded-xl shadow">
      <h4 class="text-2xl font-semibold mb-6">Login</h4>

      <form action="/users/login" method="post" class="space-y-4">
        <input class="w-full border px-4 py-2 rounded" name="email" placeholder="Email">
        <input class="w-full border px-4 py-2 rounded" type="password" name="password" placeholder="Password">

        <button class="w-full py-2 bg-black text-white rounded hover:bg-gray-800">
          Login
        </button>
      </form>
    </div>
  </div>
<%- include("partials/footer") %>
